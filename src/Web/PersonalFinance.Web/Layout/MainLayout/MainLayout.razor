@using PersonalFinance.Web.Layout.HeaderMain
@using PersonalFinance.Web.Layout.NavMenu
@using PersonalFinance.Web.Pages.Login.Main
@inherits LayoutComponentBase

<div class="page">
    @if (!_isAuthenticated)
    {
        <Login/>
    }
    else
    {
        <NavMenu/>

        <main class="page-main">
            <HeaderMain/>
            <div class="page-content">
                @Body
            </div>
        </main>
    }

</div>