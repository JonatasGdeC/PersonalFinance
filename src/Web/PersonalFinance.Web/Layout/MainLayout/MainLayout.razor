@using PersonalFinance.Web.Layout.NavMenu
@using PersonalFinance.Web.Pages.Login.Main
@inherits LayoutComponentBase

<div class="page">
    @if (!_isAuthenticated)
    {
        <Login/>
    }
    else
    {
        <div class="sidebar">
            <NavMenu/>
        </div>

        <main>
            @Body
        </main>
    }

</div>