@using PersonalFinance.Web.Resources.Login

<form class="form-register-user" @onsubmit="@HandleRegisterUser">
    <AddText Text="@LoginResources.SignUp" Preset="TextPreset.Preset1" TagHtml="TagText.H1"/>

    <div class="form-register-user__inputs">
        <AddInput Label="@LoginResources.Name" @bind-Value="_registerUserRequest.Name" 
                  Required="true" Disabled="_isSubmitting" />
        <AddInput Label="@LoginResources.Email" @bind-Value="_registerUserRequest.Email"
                  IsEmail="true" Required="true" Disabled="_isSubmitting"/>
        <AddInput Label="@LoginResources.CreatePassword" @bind-Value="_registerUserRequest.Password"
                  IsPassword="true" Required="true" Disabled="_isSubmitting"
                  HelperText="@(_registerUserRequest.Password.Length < 8 ? LoginResources.PasswordMinLength : string.Empty)"/>

        @foreach (string errorMessage in _errorMessage)
        {
            <AddText Text="@errorMessage" Color="ThemeColor.Red" Preset="TextPreset.Preset5"/>
        }
    </div>

    <AddButton Text="@(_isSubmitting ? LoginResources.LoggingIn : LoginResources.SignUp)"
               Variant="ButtonVariant.Primary" Type="submit"
               FullWidth="true" Disabled="_isSubmitting"/>

    <div class="form-register-user__footer">
        <AddText Text="@LoginResources.AlreadyHaveAccount" Preset="TextPreset.Preset4" Color="ThemeColor.Grey500"/>
        <AddButton Text="@LoginResources.Login" Variant="ButtonVariant.Link" OnClick="@(async _ => await NavigateToLogin.InvokeAsync())"/>
    </div>
</form>